# Copy to .env.local and fill in. .env.local is gitignored.

# ---------------------------------------------------------------------------
# Database — Postgres on Neon
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ---------------------------------------------------------------------------
# Stripe — TEST MODE keys (start with sk_test_… / pk_test_…). See docs/stripe.md.
# Get them from https://dashboard.stripe.com/test/apikeys
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_…
# NEXT_PUBLIC_ prefix is required so the publishable key is exposed to client code.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_…

# Webhook signing secret. Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and copy the whsec_… it prints. The CLI is single-tenant per machine, so
# in dev this stays on your laptop.
STRIPE_WEBHOOK_SECRET=whsec_…

# Public app URL — used for canonical links, OG image URLs, Checkout
# success/cancel URLs, sitemap entries, and the LodgingBusiness JSON-LD.
#
# Must include the https:// scheme. Required for local dev (Vercel falls
# back to VERCEL_PROJECT_PRODUCTION_URL → VERCEL_URL → localhost when this
# is unset — see src/lib/site.ts:siteUrl).
#
# Production: set to https://fincasanmateo.com (or whatever the custom
# domain ends up being). Never set this to a bare hostname; the build
# normalises but config-by-convention is clearer.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Google Search Console — site verification meta tag
# ---------------------------------------------------------------------------
# Paste the content of the `<meta name="google-site-verification" ...>` tag
# from Search Console here. When set, the meta tag is emitted on every page
# via baseMetadata() and GSC will verify the domain. Leave empty otherwise.
# Docs: docs/seo.md → "Google Search Console setup".
GOOGLE_SITE_VERIFICATION=

# ---------------------------------------------------------------------------
# Cloudinary — image CDN. See docs/cloudinary.md for folder conventions.
# Get the cloud name + API key + secret from https://cloudinary.com → dashboard.
# ---------------------------------------------------------------------------
# Exposed to the client — next-cloudinary needs it to build image URLs.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# Server-only. Combined URL form the Node SDK auto-picks up:
#   cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
